  m_Text: "\u0417\u0430 \u0432\u0441\u0435 \u0433\u043E\u0434\u044B \u0437\u0430\u0442\u043E\u0447\u0435\u043D\u0438\u044F
    \u0432 \u043A\u0430\u043C\u0435\u0440\u0435 \u0433\u0435\u0440\u043E\u0439 \u043D\u0435
    \u043F\u043E\u0442\u0435\u0440\u044F\u043B \u0441\u0432\u043E\u0438\u0445 \u0441\u0438\u043B.
